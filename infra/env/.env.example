# Database
DATABASE_URL=postgresql://admin:password@localhost:5432/blood_donor_admin

# JWT
JWT_SECRET=change-me-to-a-random-secret

# Google Sheets API key (required for sheet import)
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_SHEETS_API_KEY=

# Public URL where Apps Script webhooks will reach your API
# For local testing with ngrok: https://your-subdomain.ngrok.io
# For production: https://your-domain.com
PORTAL_URL=http://localhost:4000

# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000