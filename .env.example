# Supabase Configuration
# Get these from your Supabase project dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Sheets API key (required for sheet import)
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key

# Public URL where the app is deployed (used in Apps Script templates)
# For Vercel: https://your-app.vercel.app
# For development: http://localhost:3000
PORTAL_URL=http://localhost:3000

# Public portal URL (for client-side use)
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# Donor portal URL (external domain for public registration forms)
# This is the domain where donors will access registration pages
# e.g., https://bloodserve-portal.com
NEXT_PUBLIC_DONOR_PORTAL_URL=http://localhost:3000
